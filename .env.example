APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./data/svn_ai_review.db
CONFIG_PATH=./config.yaml
TIMEZONE=Asia/Shanghai
LOCAL_TIMEZONE_OFFSET_HOURS=8
TEAMS_WEBHOOK_URL=
SVN_USERNAME=
SVN_PASSWORD=

# ═══ Frontend（Next.js static export 构建时生效）═══
# 留空使用相对路径（默认，前后端同源部署）
# 如前后端分离部署，填写后端地址，例如：http://192.168.1.100:8000
NEXT_PUBLIC_API_BASE=

# AI Provider API Keys（在 UI Settings 中配置提供商标板后在此填写对应 Key）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Email 通知（SMTP）
EMAIL_SMTP_PASSWORD=
